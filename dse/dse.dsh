		grid "pc1.dsh" 15 95  48 20 40
		grid "pc2.dsh" 61 117 80 21 40
		image "images/original-plate-01.jpg" imx 90 8 0
		image "images/original-plate-15.jpg" imx 70 8 0
		image "images/original-plate-14.jpg" imx 50 8 0
		image "images/original-plate-27.jpg" imx 30 8 0
