		hline 45 65 45 5 "yellow" 50
	eslide

	slide bgcolor fgcolor
		ctext "Did Du Bois Do Enough?" tx ty ts "sans" spotcolor
		image "images/pba-occupations.jpg" 20 50 33 0
		textblock hope 40 80 40 2.5 "serif"
	eslide

	// Notables from the Du Bois Challenge

	slide bgcolor fgcolor
		ctext "The Du Bois Challenge" mid mid ss "sans" spotcolor
	eslide

