		image "images/church-service.jpg" imx 30 8 0
		image "images/original-plate-37.jpg" imx 10 8 0
	eslide

	imx=25
	imy=50
	imw=35
	annw=35
	annts=3
	annx=48
	anny=65
	imw2=imw+7

